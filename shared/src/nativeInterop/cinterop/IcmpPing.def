package = com.yuroyami.pingy.native.icmp
language = C
---
#include <sys/socket.h>
#include <netinet/in.h>
#include <netinet/ip.h>
#include <netinet/ip_icmp.h>
#include <netdb.h>
#include <arpa/inet.h>
#include <sys/time.h>
#include <time.h>
#include <poll.h>
#include <unistd.h>
#include <string.h>
#include <errno.h>
#include <stdint.h>

/* Helper to get errno value since Kotlin/Native can't always read it directly */
static inline int get_errno(void) {
    return errno;
}

/* Standard BSD Internet checksum used for ICMP packets (same algorithm as SPLPing's in_cksum). */
static inline uint16_t icmp_in_cksum(const uint8_t *buffer, int len) {
    int32_t sum = 0;
    const uint16_t *cursor = (const uint16_t *)buffer;
    int bytes_left = len;

    while (bytes_left > 1) {
        sum += *cursor++;
        bytes_left -= 2;
    }
    if (bytes_left == 1) {
        uint16_t last = 0;
        *((uint8_t *)&last) = *((const uint8_t *)cursor);
        sum += last;
    }
    sum = (sum >> 16) + (sum & 0xffff);
    sum += (sum >> 16);
    return (uint16_t)~sum;
}

/* Build an ICMP echo request packet into the provided buffer.
   Returns the total packet size (header + payload). */
static inline int build_icmp_echo_request(
    void *buf,
    int buf_size,
    uint16_t identifier,
    uint16_t sequence_number,
    int payload_size
) {
    if (buf_size < (int)(sizeof(struct icmp) + payload_size)) return -1;

    struct icmp *icmp_hdr = (struct icmp *)buf;
    memset(icmp_hdr, 0, sizeof(struct icmp) + payload_size);

    icmp_hdr->icmp_type = ICMP_ECHO;
    icmp_hdr->icmp_code = 0;
    icmp_hdr->icmp_id = htons(identifier);
    icmp_hdr->icmp_seq = htons(sequence_number);

    /* Fill payload with a pattern (matches SPLPing convention of 0x07 repeat) */
    char *payload = (char *)buf + sizeof(struct icmp);
    for (int i = 0; i < payload_size; i++) {
        payload[i] = (char)(0x07);
    }

    /* Compute checksum over the full ICMP message (header + payload). */
    icmp_hdr->icmp_cksum = 0;
    int total_size = (int)sizeof(struct icmp) + payload_size;
    icmp_hdr->icmp_cksum = icmp_in_cksum((const uint8_t *)buf, total_size);

    return total_size;
}

/* Parse an ICMP echo reply from a raw IP packet buffer as delivered by
   SOCK_DGRAM+IPPROTO_ICMP on Darwin (which includes the full IPv4 header).
   Returns:
       0  — parse OK, checksum valid, fields filled.
      -1  — buffer too small or malformed.
      -2  — checksum mismatch (reply is not ours / corrupt).
   On 0, fills out_id/out_seq/out_type/out_code. */
static inline int parse_icmp_echo_reply(
    const void *buf,
    int buf_len,
    uint16_t *out_id,
    uint16_t *out_seq,
    uint8_t *out_type,
    uint8_t *out_code
) {
    if (buf_len < (int)(sizeof(struct ip) + 8)) return -1;

    const struct ip *ip_hdr = (const struct ip *)buf;
    /* Sanity check: IPv4 + ICMP */
    if ((ip_hdr->ip_v != 4) || (ip_hdr->ip_p != IPPROTO_ICMP)) {
        /* Not fatal — continue best-effort; callers that care will look at type. */
    }

    int ip_hdr_len = ip_hdr->ip_hl << 2;
    if (ip_hdr_len < 20 || buf_len < ip_hdr_len + 8) return -1;

    const uint8_t *icmp = (const uint8_t *)buf + ip_hdr_len;
    int icmp_len = buf_len - ip_hdr_len;

    /* Extract fields directly (tolerate unaligned reads via byte pick). */
    *out_type = icmp[0];
    *out_code = icmp[1];
    uint16_t received_cksum;
    memcpy(&received_cksum, icmp + 2, sizeof(uint16_t));
    uint16_t id_be, seq_be;
    memcpy(&id_be, icmp + 4, sizeof(uint16_t));
    memcpy(&seq_be, icmp + 6, sizeof(uint16_t));
    *out_id = ntohs(id_be);
    *out_seq = ntohs(seq_be);

    /* Verify checksum. Because we must treat the checksum field as zero when
       recomputing, we split the sum into "bytes before cksum + zero + bytes after". */
    int32_t sum = 0;
    /* First 16-bit word: type + code */
    uint16_t w;
    memcpy(&w, icmp, 2); sum += w;
    /* Skip checksum field (2 bytes, treated as 0) */
    /* Remaining words */
    int offset = 4;
    while (offset + 1 < icmp_len) {
        memcpy(&w, icmp + offset, 2);
        sum += w;
        offset += 2;
    }
    if (offset < icmp_len) {
        uint16_t last = 0;
        *((uint8_t *)&last) = icmp[offset];
        sum += last;
    }
    sum = (sum >> 16) + (sum & 0xffff);
    sum += (sum >> 16);
    uint16_t computed = (uint16_t)~sum;

    if (computed != received_cksum) return -2;

    return 0;
}

/* Create an unprivileged ICMP socket (SOCK_DGRAM + IPPROTO_ICMP).
   On Darwin, the kernel manages a unique per-socket identifier and rewrites
   the ICMP id field on send/filters replies on receive — so callers should
   NOT rely on the identifier they set being echoed back verbatim. */
static inline int create_icmp_socket(void) {
    return socket(AF_INET, SOCK_DGRAM, IPPROTO_ICMP);
}

/* Resolve hostname to IPv4 address string. Returns 0 on success,
   or the getaddrinfo error code (positive) / -1 for inet_ntop failure. */
static inline int resolve_host(const char *hostname, char *ip_buf, int ip_buf_size) {
    /* Fast path: numeric IPv4 literal — bypass DNS entirely. */
    struct in_addr addr4;
    if (inet_pton(AF_INET, hostname, &addr4) == 1) {
        if (inet_ntop(AF_INET, &addr4, ip_buf, ip_buf_size) == NULL) return -1;
        return 0;
    }

    /* Slow path: DNS. Leave ai_socktype / ai_protocol at 0 — Darwin's
       getaddrinfo refuses combinations like (SOCK_DGRAM + IPPROTO_ICMP)
       when `service` is NULL, failing every lookup including numeric IPs. */
    struct addrinfo hints;
    struct addrinfo *result = NULL;

    memset(&hints, 0, sizeof(hints));
    hints.ai_family = AF_INET;

    int ret = getaddrinfo(hostname, NULL, &hints, &result);
    if (ret != 0 || result == NULL) return (ret != 0) ? ret : -1;

    struct sockaddr_in *addr = (struct sockaddr_in *)result->ai_addr;
    if (inet_ntop(AF_INET, &addr->sin_addr, ip_buf, ip_buf_size) == NULL) {
        freeaddrinfo(result);
        return -1;
    }

    freeaddrinfo(result);
    return 0;
}

/* Monotonic wall clock in microseconds. Prefer CLOCK_MONOTONIC so NTP adjustments
   don't skew an in-flight RTT measurement (gettimeofday is subject to them). */
static inline int64_t get_time_usec(void) {
#if defined(CLOCK_MONOTONIC)
    struct timespec ts;
    if (clock_gettime(CLOCK_MONOTONIC, &ts) == 0) {
        return (int64_t)ts.tv_sec * 1000000LL + (int64_t)ts.tv_nsec / 1000LL;
    }
#endif
    struct timeval tv;
    gettimeofday(&tv, NULL);
    return (int64_t)tv.tv_sec * 1000000LL + (int64_t)tv.tv_usec;
}

/* Send ICMP packet to the given IPv4 address string. Returns bytes sent or -1. */
static inline int send_icmp_packet(int sockfd, const char *ip_addr, const void *packet, int packet_len) {
    struct sockaddr_in dest;
    memset(&dest, 0, sizeof(dest));
    dest.sin_family = AF_INET;
    inet_pton(AF_INET, ip_addr, &dest.sin_addr);

    return (int)sendto(sockfd, packet, packet_len, 0, (struct sockaddr *)&dest, sizeof(dest));
}

/* Receive ICMP reply with timeout in milliseconds. Returns bytes received or -1. */
static inline int recv_icmp_packet(int sockfd, void *buf, int buf_size, int timeout_ms) {
    struct pollfd pfd;
    pfd.fd = sockfd;
    pfd.events = POLLIN;
    pfd.revents = 0;

    int ret = poll(&pfd, 1, timeout_ms);
    if (ret <= 0) return -1; /* timeout or error */

    return (int)recvfrom(sockfd, buf, buf_size, 0, NULL, NULL);
}

/* Open an unprivileged ICMP socket and `connect()` it to an IPv4 literal.
 * Mirrors nativeOpenSocket in shared/native/icmp_ping.c. Returns fd on
 * success, or -1 on any failure. Hostnames are NOT accepted — the caller
 * (PingEngine) does resolution once in Kotlin and caches the result.
 *
 * Connecting pins the 4-tuple so subsequent send()s skip per-packet route
 * lookups. That, plus reusing the same fd across probes, shaves the
 * socket()+close() churn and the route cache miss a 5 Hz ping stream
 * otherwise pays on every probe. */
static inline int open_icmp_socket_connected(const char *ipv4) {
    if (ipv4 == NULL) return -1;
    int fd = socket(AF_INET, SOCK_DGRAM, IPPROTO_ICMP);
    if (fd < 0) return -1;
    struct sockaddr_in dest;
    memset(&dest, 0, sizeof(dest));
    dest.sin_family = AF_INET;
    if (inet_pton(AF_INET, ipv4, &dest.sin_addr) != 1) { close(fd); return -1; }
    if (connect(fd, (struct sockaddr *)&dest, sizeof(dest)) < 0) { close(fd); return -1; }
    return fd;
}

/* Close a socket previously returned by open_icmp_socket_connected.
 * Idempotent on negative fds. */
static inline void close_icmp_socket(int fd) {
    if (fd >= 0) close(fd);
}

/* Perform one ICMP probe over a previously opened+connected socket.
 * Mirrors nativePingOnSocket in shared/native/icmp_ping.c — the whole
 * send/poll/recv/timestamp dance runs inside this single C function so the
 * measured window stays free of K/N↔C boundary crossings.
 *
 * Return contract (same as the JNI side):
 *   rtt >= 0.0  — success, RTT in ms
 *   -1.0        — socket-level failure; caller should close+reopen the fd
 *   -2.0        — timeout / no matching reply; socket is still healthy
 */
static inline double ping_once_on_socket(int fd, int timeout_ms, int payload_size) {
    if (fd < 0 || timeout_ms <= 0 || payload_size < 0 || payload_size > 480) {
        return -1.0;
    }

    unsigned char packet[512];
    int packet_size = build_icmp_echo_request(packet, sizeof(packet), 0xABCD, 1, payload_size);
    if (packet_size < 0) return -1.0;

    int64_t send_us = get_time_usec();
    /* send() instead of sendto() — socket is connected, kernel skips route lookup. */
    if (send(fd, packet, packet_size, 0) < 0) return -1.0;

    unsigned char recv_buf[1024];
    int remaining_ms = timeout_ms;
    while (remaining_ms > 0) {
        int64_t wait_start_us = get_time_usec();
        struct pollfd pfd;
        pfd.fd = fd;
        pfd.events = POLLIN;
        pfd.revents = 0;
        int pr = poll(&pfd, 1, remaining_ms);
        if (pr < 0) return -1.0;
        if (pr == 0) return -2.0;

        int n = (int)recv(fd, recv_buf, sizeof(recv_buf), 0);
        if (n < 0) return -1.0;

        uint16_t id_out = 0, seq_out = 0;
        uint8_t type_out = 0, code_out = 0;
        int parsed = parse_icmp_echo_reply(recv_buf, n, &id_out, &seq_out, &type_out, &code_out);
        /* type 0 = ECHOREPLY. Darwin's kernel demuxes per-socket so any
           ECHOREPLY we see is already ours — no id/seq match required. */
        if (parsed == 0 && type_out == 0) {
            int64_t recv_us = get_time_usec();
            double rtt_ms = (double)(recv_us - send_us) / 1000.0;
            if (rtt_ms < 0.0) rtt_ms = 0.0;
            return rtt_ms;
        }

        int64_t now_us = get_time_usec();
        int elapsed_ms = (int)((now_us - wait_start_us) / 1000);
        if (elapsed_ms < 1) elapsed_ms = 1;
        remaining_ms -= elapsed_ms;
    }
    return -2.0;
}
